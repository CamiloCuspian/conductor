---
import type { City } from "../data/cities";
import BaseLayout from "../layouts/BaseLayout.astro";
import WhatsAppButton from "./WhatsAppButton.astro";
import FAQ from "./FAQ.astro";
import { services } from "../data/services";
import { site, waUrl } from "../config";

interface Props {
  city: City;
}

const { city } = Astro.props;
const base = site.base;
const canonicalUrl = `${site.siteUrl}${base}/${city.slug}/`;

const waMsg = encodeURIComponent(
  `Hola, necesito un conductor ${city.preposition}. ¿Tienes disponibilidad?`
);
---

<BaseLayout title={city.title} description={city.description} canonical={canonicalUrl}>

  <section class="city-hero seccion-completa seccion-completa--oscuro" aria-label={city.h1}>
    <div class="wrapper">
      <div class="two_columns city-hero-grid">
        <div class="flow">
          <div class="badge badge--light">📍 {city.name}</div>

          <h1>{city.h1}</h1>

          <p class="city-intro">{city.intro}</p>

          <ul class="hero-bullets" role="list">
            <li>✅ Conductor certificado y con experiencia</li>
            <li>✅ Tu carro o el mío — tú decides</li>
            <li>✅ Cobertura en toda la ciudad y alrededores</li>
            <li>✅ Respuesta inmediata por WhatsApp</li>
          </ul>

          <div class="flex-responsive hero-cta" style="--gap: 1rem; --justify: flex-start; --min-width: 180px;">
            <WhatsAppButton text={`Conductor ${city.preposition}`} message={waMsg} />
            <a href={`${base}/#contacto`} class="btn btn-secondary">
              📋 Formulario de contacto
            </a>
          </div>
        </div>

        <div class="city-stats" aria-label="Estadísticas del servicio">
          {city.stats.map(({ number, label }) => (
            <div class="stat-card">
              <span class="stat-number">{number}</span>
              <span class="stat-label">{label}</span>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <section aria-labelledby={`servicios-${city.slug}`} class="seccion-completa seccion-completa--gris">
    <div class="padding">
      <div class="section">
        <div class="section-intro">
          <div class="badge">Servicios</div>
          <h2 id={`servicios-${city.slug}`}>
            Conductor {city.preposition} para cada ocasión
          </h2>
          <p>Traslados al {city.airport}, eventos, empresas y uso diario.</p>
        </div>

        <div class="cards-grid">
          {services.map((s) => (
            <article class="card card--interactive">
              <div class="service-icon" aria-hidden="true">{s.icon}</div>
              <h3>{s.title}</h3>
              <p>{s.description}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section aria-labelledby={`zonas-${city.slug}`}>
    <div class="padding">
      <div class="section">
        <div class="two_columns zones-grid">

          <div class="flow">
            <div class="badge">Cobertura</div>
            <h2 id={`zonas-${city.slug}`}>
              ¿En qué zonas de {city.name} opero?
            </h2>
            <p>
              Cubro toda la ciudad y municipios del área metropolitana.
              Si tu barrio no aparece en la lista, escríbeme por WhatsApp
              — con gusto verifico disponibilidad para tu zona.
            </p>
            <WhatsAppButton
              text="Verificar mi zona"
              message={waMsg}
            />
          </div>

          <div class="zones-list-wrapper">
            <ul class="zones-list" aria-label={`Zonas cubiertas ${city.preposition}`}>
              {city.zones.map((zone) => (
                <li>
                  <span class="zone-dot" aria-hidden="true">📍</span>
                  {zone}
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </div>
  </section>

  <section
    aria-labelledby={`aeropuerto-${city.slug}`}
    class="seccion-completa seccion-completa--acento"
  >
    <div class="padding">
      <div class="section">
        <div class="two_columns two_columns--reverse airport-section">

          <div class="airport-visual" aria-hidden="true">
            <div class="airport-icon">✈️</div>
            <p class="airport-name">{city.airport}</p>
          </div>

          <div class="flow">
            <div class="badge">Aeropuerto</div>
            <h2 id={`aeropuerto-${city.slug}`}>
              Traslados al {city.airport}
            </h2>
            <p>
              El traslado al aeropuerto es uno de los servicios más solicitados.
              Llego puntual, monitoreo tu vuelo y te llevo sin estrés.
              Disponible para vuelos madrugadores, nocturnos y de fin de semana.
            </p>
            <ul class="flow flow--sm" role="list" style="list-style: none; padding: 0;">
              <li>🕐 Servicio disponible las 24 horas</li>
              <li>📱 Confirma tu vuelo la noche anterior</li>
              <li>🧳 Ayuda con el equipaje incluida</li>
              <li>💳 Pago al finalizar: efectivo, Nequi o transferencia</li>
            </ul>
            <WhatsAppButton
              text="Reservar traslado al aeropuerto"
              message={waMsg}
            />
          </div>

        </div>
      </div>
    </div>
  </section>

  <FAQ
    faqs={city.faqs}
    title={`Preguntas frecuentes — Conductor ${city.preposition}`}
    badge="FAQ"
  />

  <section class="seccion-completa seccion-completa--principal cta-final">
    <div class="padding">
      <div class="section">
        <div class="text-center flow">
          <h2>¿Listo para reservar tu conductor {city.preposition}?</h2>
          <p>
            Respuesta en menos de 3 minutos. Sin apps, sin complicaciones.
            Solo escríbeme y coordinamos tu servicio.
          </p>
          <div class="flex-responsive" style="--gap: 1rem; --min-width: 200px;">
            <WhatsAppButton
              text={`Contratar conductor ${city.preposition}`}
              message={waMsg}
            />
            <a href={`${base}/#contacto`} class="btn btn-secondary">
              Ir al formulario
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": `${site.name} — ${city.name}`,
    "description": city.description,
    "telephone": site.phoneFull,
    "email": site.email,
    "url": `${site.siteUrl}${site.base}/${city.slug}/`,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": city.name,
      "addressRegion": city.name,
      "addressCountry": "CO",
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": city.geo.lat,
      "longitude": city.geo.lng,
    },
    "areaServed": {
      "@type": "City",
      "name": city.name,
    },
    "priceRange": site.priceRange,
    "openingHours": site.openingHours,
  })} />

</BaseLayout>

<style>
  .city-hero {
    padding-block: 2rem 0;
    color: white;
  }

  .city-hero-grid {
    gap: 3rem;
    align-items: center;
  }

  .badge--light {
    background: rgba(255, 255, 255, 0.15);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .city-hero h1 { color: white; }

  .city-intro {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.85);
    max-width: 55ch;
  }

  .hero-bullets {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.95rem;
  }

  .hero-cta { margin-top: 0.5rem; }

  .city-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .stat-card {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius);
    padding: 1.25rem 1rem;
    text-align: center;
    backdrop-filter: blur(4px);
  }

  .stat-number {
    display: block;
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-secundario);
  }

  .stat-label {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.3;
  }

  .service-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .card h3 { margin-bottom: 0.5rem; font-size: 1.1rem; }
  .card p  { color: var(--color-texto-suave); font-size: 0.95rem; max-width: none; }

  .zones-list-wrapper {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-borde);
    border-radius: var(--radius-lg);
    padding: 1.5rem 2rem;
  }

  .zones-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .zones-list li {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.95rem;
    color: var(--color-texto);
    max-width: none;
  }

  .zone-dot { font-size: 0.8rem; }

  .airport-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 3rem;
    background: rgba(26, 86, 219, 0.06);
    border-radius: var(--radius-lg);
    border: 2px dashed var(--color-principal);
    text-align: center;
  }

  .airport-icon { font-size: 5rem; line-height: 1; }

  .airport-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-principal);
    max-width: 24ch;
    text-align: center;
  }

  .cta-final { color: white; }
  .cta-final h2 { color: white; }
  .cta-final p  { color: rgba(255, 255, 255, 0.85); }

  @media (max-width: 768px) {
    .city-stats { grid-template-columns: repeat(2, 1fr); }
    .zones-list { grid-template-columns: 1fr; }
    .hero-cta { flex-direction: column; }
    .hero-cta :global(.btn) { width: 100%; justify-content: center; }
    .airport-visual { padding: 2rem 1rem; }
    .airport-icon { font-size: 3.5rem; }
  }
</style>
