---
import { site, waUrl } from "../config";
import WhatsAppButton from "./WhatsAppButton.astro";

const base = site.base;
const bullets = [
  "✅ Conductor certificado y con experiencia",
  "✅ Tu carro o el mío — tú decides",
  "✅ Tarifas claras, sin sorpresas",
  "✅ Respuesta inmediata por WhatsApp",
];
---

<section class="hero" aria-label="Conductor privado en Bogotá">
  <div class="hero-bg" aria-hidden="true"></div>

  <div class="container hero-content">
    <div class="hero-text">
      <div class="badge hero-badge">⭐ +500 viajes en Bogotá</div>

      <h1>
        {site.name}<br />
        <span class="hero-highlight">en Bogotá</span>
      </h1>

      <p class="hero-description">
        ¿Necesitas un conductor de confianza en Bogotá?
        Servicio profesional, puntual y seguro para eventos,
        aeropuerto, empresas y uso diario. Disponible 24/7.
      </p>

      <ul class="hero-bullets" role="list">
        {bullets.map((bullet) => <li>{bullet}</li>)}
      </ul>

      <div class="hero-cta">
        <WhatsAppButton text="Solicitar por WhatsApp" />
        <a href={`${base}/#contacto`} class="btn btn-secondary">
          📋 Enviar formulario
        </a>
      </div>
    </div>

    <div class="hero-stats" aria-label="Estadísticas del servicio">
      {site.stats.map(({ number, label }) => (
        <div class="stat-card">
          <span class="stat-number">{number}</span>
          <span class="stat-label">{label}</span>
        </div>
      ))}
    </div>
  </div>

  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none">
      <path d="M0,60 C480,0 960,60 1440,0 L1440,60 Z" fill="white"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: linear-gradient(135deg, #1a56db 0%, #1e3a8a 50%, #0f172a 100%);
    color: white;
    padding-top: 5rem;
    padding-bottom: 3rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.08) 1px, transparent 1px);
    background-size: 30px 30px;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
  }

  .hero-badge {
    background: rgba(255,255,255,0.15);
    color: white;
    border: 1px solid rgba(255,255,255,0.25);
  }

  .hero-text { max-width: 600px; }
  .hero-text h1 { color: white; margin-bottom: 1.25rem; }
  .hero-highlight { color: var(--color-secundario); }

  .hero-description {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 1.5rem;
    max-width: 55ch;
  }

  .hero-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
    color: rgba(255,255,255,0.9);
    font-size: 0.95rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  .stat-card {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: var(--radius);
    padding: 1.25rem 1rem;
    text-align: center;
    backdrop-filter: blur(4px);
  }
  .stat-number {
    display: block;
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-secundario);
  }
  .stat-label {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.3;
  }

  .hero-wave {
    position: relative;
    height: 60px;
    margin-top: 2rem;
  }
  .hero-wave svg {
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-bullets { align-items: flex-start; text-align: left; }
    .hero-cta { justify-content: center; }
    .hero-stats { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .hero-cta { flex-direction: column; }
    .hero-cta :global(.btn) { width: 100%; justify-content: center; }
  }
</style>
